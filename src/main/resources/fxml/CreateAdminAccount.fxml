<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.CreateAdminAccountController"
    stylesheets="@../css/styles.css"
    prefWidth="860" prefHeight="520">
    <left>
        <VBox alignment="CENTER" prefWidth="420" styleClass="admin-login-left">
            <padding>
                <Insets top="0" bottom="0" left="40" right="40" />
            </padding>
            <VBox alignment="CENTER" spacing="14" styleClass="admin-login-card">
                <padding>
                    <Insets top="36" bottom="36" left="36" right="36" />
                </padding>
                <Label text="Create Admin Account" styleClass="admin-login-title" alignment="CENTER"
                    maxWidth="Infinity" />
                <VBox spacing="5">
                    <Label text="Username *" styleClass="form-label" />
                    <TextField fx:id="usernameField" promptText="Enter username"
                        styleClass="form-input" />
                </VBox>
                <VBox spacing="5">
                    <Label text="Password *" styleClass="form-label" />
                    <PasswordField fx:id="passwordField" promptText="Enter password"
                        styleClass="form-input" />
                </VBox>
                <VBox spacing="5">
                    <Label text="Confirm Password *" styleClass="form-label" />
                    <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password"
                        styleClass="form-input" />
                </VBox>
                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"
                    maxWidth="Infinity" />
                <Button text="CREATE ACCOUNT" styleClass="btn-view" maxWidth="Infinity"
                    onAction="#onCreateAccount" />
                <HBox alignment="CENTER" spacing="4">
                    <Label text="Already have an account?" styleClass="forgot-text" />
                    <Hyperlink text="Log in here" styleClass="forgot-link" onAction="#onBackToLogin" />
                </HBox>
            </VBox>
        </VBox>
    </left>
    <center>
        <StackPane styleClass="login-left-panel">
            <ImageView fx:id="bgImage" fitWidth="460" fitHeight="520" preserveRatio="false" />
            <Pane styleClass="login-overlay" />
            <VBox alignment="CENTER" spacing="16">
                <ImageView fx:id="logoImage" fitWidth="90" fitHeight="90" preserveRatio="true" />
                <Label text="PUPSRC LOST AND FOUND" styleClass="login-welcome-line2" wrapText="true"
                    alignment="CENTER" textAlignment="CENTER" maxWidth="260" />
            </VBox>
        </StackPane>
    </center>
</BorderPane>